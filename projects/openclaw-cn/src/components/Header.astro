---
import { SITE_CONFIG } from "../config";

const normalizePath = (value: string) =>
  value.length > 1 && value.endsWith("/") ? value.slice(0, -1) : value;

const pathname = normalizePath(Astro.url.pathname);
---

<header class="sticky top-0 z-50 glass-nav">
  <nav class="page-shell">
    <div class="flex min-h-[4.5rem] items-center justify-between gap-4 py-3">
      <div class="flex items-center gap-4 sm:gap-8">
        <a href="/" class="group flex items-center gap-3">
          <div
            class="flex h-11 w-11 items-center justify-center rounded bg-slate-900 text-lg font-bold text-brand-500 shadow-[2px_2px_0_#9b2c2c] font-pixel transition group-hover:scale-105 border-2 border-slate-700"
          >
            {">_"}
          </div>
          <div class="min-w-0">
            <div
              class="text-base font-semibold tracking-tight text-slate-950 transition group-hover:text-brand-700 sm:text-xl font-pixel flex items-center gap-1"
            >
              OpenClaw<span
                class="text-brand-500 text-2xl inline-block -translate-y-0.5"
                >🦞</span
              >
            </div>
            <div
              class="hidden text-xs text-slate-500 sm:block font-mono tracking-wider"
            >
              [COMMUNITY_ENTRYPOINT]
            </div>
          </div>
        </a>

        <div class="hidden md:flex md:items-center md:gap-1">
          {
            SITE_CONFIG.nav.map((item) => (
              <a
                href={item.href}
                class={`nav-link ${
                  normalizePath(item.href) === pathname ? "nav-link-active" : ""
                }`}
              >
                <span data-i18n={`nav.${item.href === '/' ? 'home' : item.href === '/skills' ? 'skills' : 'tutorials'}`}>{item.name}</span>
              </a>
            ))
          }
        </div>
      </div>

      <div class="hidden items-center gap-3 md:flex">
        <!-- 语言切换按钮 -->
        <button
          id="lang-switch-btn"
          onclick="toggleLang()"
          title="切换语言 / Switch Language"
          class="inline-flex h-9 items-center justify-center rounded border-2 border-slate-700 bg-slate-900 px-3 text-xs font-bold text-slate-300 font-pixel tracking-wider shadow-[2px_2px_0_#e53e3e] transition hover:bg-slate-800 hover:text-brand-400 cursor-pointer"
        >
          EN
        </button>
        <a
          href={SITE_CONFIG.social.github}
          target="_blank"
          rel="noopener noreferrer"
          class="secondary-button hidden lg:inline-flex"
        >
          GitHub
        </a>
        <a href="/tutorials" class="primary-button px-4 py-2">
          <span data-i18n="nav.getStarted">开始上手</span>
        </a>
      </div>

      <div class="md:hidden flex items-center">
        <button
          data-mobile-menu-button
          class="inline-flex h-11 w-11 items-center justify-center rounded-2xl border border-slate-200 bg-white text-slate-600 transition hover:border-brand-200 hover:text-brand-700"
          aria-label="打开菜单"
          aria-expanded="false"
          aria-controls="mobile-menu"
        >
          <svg
            data-menu-open-icon
            class="h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <svg
            data-menu-close-icon
            class="hidden h-6 w-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <div
    id="mobile-menu"
    data-mobile-menu
    class="page-shell hidden md:hidden pb-4"
  >
    <div class="surface-card space-y-2 p-4">
      {
        SITE_CONFIG.nav.map((item) => (
          <a
            href={item.href}
            class={`block rounded-2xl px-4 py-3 text-base font-medium transition ${
              normalizePath(item.href) === pathname
                ? "bg-brand-50 text-brand-700"
                : "text-slate-700 hover:bg-slate-50 hover:text-brand-700"
            }`}
          >
            <span data-i18n={`nav.${item.href === '/' ? 'home' : item.href === '/skills' ? 'skills' : 'tutorials'}`}>{item.name}</span>
          </a>
        ))
      }
      <div class="mt-3 grid gap-3 border-t border-slate-100 pt-4">
        <button
          onclick="toggleLang()"
          class="secondary-button w-full text-center cursor-pointer"
        >
          <span id="lang-switch-btn-mobile">EN / 切换语言</span>
        </button>
        <a
          href={SITE_CONFIG.social.github}
          target="_blank"
          rel="noopener noreferrer"
          class="secondary-button w-full"
        >
          <span data-i18n="nav.github">GitHub 社区</span>
        </a>
        <a href="/tutorials" class="primary-button w-full">
          <span data-i18n="nav.getStartedLong">5 分钟开始上手</span>
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const button = document.querySelector("[data-mobile-menu-button]");
  const menu = document.querySelector("[data-mobile-menu]");
  const openIcon = document.querySelector("[data-menu-open-icon]");
  const closeIcon = document.querySelector("[data-menu-close-icon]");

  const syncMenu = (expanded: boolean) => {
    if (!button || !menu || !openIcon || !closeIcon) {
      return;
    }

    button.setAttribute("aria-expanded", String(expanded));
    menu.classList.toggle("hidden", !expanded);
    openIcon.classList.toggle("hidden", expanded);
    closeIcon.classList.toggle("hidden", !expanded);
  };

  button?.addEventListener("click", () => {
    const expanded = button.getAttribute("aria-expanded") === "true";
    syncMenu(!expanded);
  });

  window.addEventListener("resize", () => {
    if (window.innerWidth >= 768) {
      syncMenu(false);
    }
  });
</script>
