---
import { SITE_CONFIG } from '../config';
---

<footer class="border-t border-white/70 py-10 sm:py-12">
  <div class="page-shell">
    <div class="surface-card px-6 py-8 sm:px-8 lg:px-10">
      <div class="grid gap-10 lg:grid-cols-[minmax(0,1.2fr)_0.8fr_0.8fr]">
        <div class="space-y-5">
          <div>
            <h3 class="text-2xl font-semibold tracking-tight text-slate-950">
              {SITE_CONFIG.title}
            </h3>
            <p class="mt-3 max-w-xl text-sm leading-7 text-slate-600 sm:text-base">
              {SITE_CONFIG.description}
            </p>
          </div>
          <div class="flex flex-wrap gap-2">
            <span class="chip">PC 端适配</span>
            <span class="chip">平板端适配</span>
            <span class="chip">移动端适配</span>
          </div>
        </div>

        <div>
          <h3 class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">
            快速入口
          </h3>
          <ul class="mt-4 space-y-3">
            {SITE_CONFIG.nav.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-sm text-slate-600 transition hover:text-brand-700"
                >
                  {item.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <div>
          <h3 class="text-sm font-semibold uppercase tracking-[0.24em] text-slate-500">
            社区与支持
          </h3>
          <div class="mt-4 space-y-4 text-sm text-slate-600">
            <p>
              微信社群：{SITE_CONFIG.social.wechat}
            </p>
            <a
              href={SITE_CONFIG.social.github}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-link"
            >
              查看 GitHub 社区
              <span aria-hidden="true">→</span>
            </a>
          </div>
        </div>
      </div>

      <div class="mt-8 flex flex-col gap-3 border-t border-slate-100 pt-6 text-sm text-slate-500 md:flex-row md:items-center md:justify-between">
        <p>
          © 2026 {SITE_CONFIG.title} · 由 {SITE_CONFIG.author} 制作
        </p>
        <p>非 OpenClaw 官方网站，仅做中文社区整理与本地化。</p>
      </div>
    </div>
  </div>
</footer>
