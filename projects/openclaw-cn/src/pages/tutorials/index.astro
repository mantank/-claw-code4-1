---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  onboardingSteps,
  tutorialTracks,
} from "../../data/site-content";

const trackAnchorId = (level: string) => `track-${level}`;
---

<BaseLayout
  title="教程中心"
  description="从安装 OpenClaw 到搭出可复用工作流，按入门、进阶、实战三段式整理中文教程路径。"
>
  <section class="section-shell pt-8 sm:pt-10 lg:pt-14">
    <div class="grid gap-6 xl:grid-cols-[minmax(0,1fr)_360px]">
      <div class="space-y-6">
        <span class="eyebrow">教程中心</span>
        <h1 class="section-title max-w-4xl text-balance">
          从第一次安装，到搭出自己的工作流
        </h1>
        <p class="section-subtitle max-w-3xl text-pretty">
          所有教程默认面向零技术背景用户，优先解决“看不懂英文文档”和“不知道下一步做什么”这两个问题。
          手机端适合快速回看步骤，平板和 PC 端适合完整阅读并跟着操作。
        </p>

        <div class="flex flex-wrap gap-3">
          {tutorialTracks.map((track) => (
            <a href={`#${trackAnchorId(track.level)}`} class="chip">
              <span>{track.icon}</span>
              <span>{track.level}</span>
            </a>
          ))}
        </div>

        <div class="grid gap-3 sm:grid-cols-3">
          <div class="metric-card">
            <div class="text-2xl font-semibold text-slate-950">{tutorialTracks.length}</div>
            <div class="mt-1 text-sm font-medium text-slate-700">阶段路径</div>
            <p class="mt-2 text-sm leading-6 text-slate-500">
              从入门、进阶到实战，避免信息一次性堆给新用户。
            </p>
          </div>
          <div class="metric-card">
            <div class="text-2xl font-semibold text-slate-950">
              {tutorialTracks.reduce((sum, track) => sum + track.items.length, 0)}
            </div>
            <div class="mt-1 text-sm font-medium text-slate-700">教程节点</div>
            <p class="mt-2 text-sm leading-6 text-slate-500">
              把每一步拆成可读、可执行、可回看的短章节。
            </p>
          </div>
          <div class="metric-card">
            <div class="text-2xl font-semibold text-slate-950">0 jargon</div>
            <div class="mt-1 text-sm font-medium text-slate-700">默认中文解释</div>
            <p class="mt-2 text-sm leading-6 text-slate-500">
              不要求用户预先理解术语，先帮你把事情做成。
            </p>
          </div>
        </div>
      </div>

      <aside class="soft-card p-6 sm:p-7">
        <span class="eyebrow">推荐顺序</span>
        <h2 class="mt-4 text-2xl font-semibold tracking-tight text-slate-950">
          按这个顺序学习，最省时间
        </h2>
        <div class="mt-5 space-y-3">
          {onboardingSteps.map((step, index) => (
            <div class="rounded-[22px] border border-white/70 bg-white/88 p-4">
              <div class="flex items-start gap-3">
                <span class="inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-brand-50 text-sm font-semibold text-brand-700">
                  0{index + 1}
                </span>
                <div>
                  <div class="text-sm font-semibold text-slate-900">{step.title}</div>
                  <p class="mt-1 text-sm leading-6 text-slate-600">
                    {step.description}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>
        <a href="/skills" class="secondary-button mt-6 w-full">
          同步查看技能列表
        </a>
      </aside>
    </div>
  </section>

  <section class="section-shell pt-0">
    <div class="grid gap-5 lg:grid-cols-3">
      {tutorialTracks.map((track) => (
        <a href={`#${trackAnchorId(track.level)}`} class="surface-card flex h-full flex-col p-6 sm:p-7">
          <div class="flex items-center justify-between gap-3">
            <span class="tag-pill tag-gray">{track.level}</span>
            <span class="text-2xl">{track.icon}</span>
          </div>
          <h2 class="mt-5 text-2xl font-semibold tracking-tight text-slate-950">
            {track.title}
          </h2>
          <p class="mt-3 text-sm leading-7 text-slate-600">
            {track.description}
          </p>
          <p class="mt-4 text-sm font-medium text-brand-700">{track.audience}</p>
        </a>
      ))}
    </div>
  </section>

  <section class="section-shell pt-0">
    <div class="space-y-5">
      {tutorialTracks.map((track) => (
        <article id={trackAnchorId(track.level)} class="surface-card p-6 sm:p-8 lg:p-10">
          <div class="grid gap-6 lg:grid-cols-[280px_minmax(0,1fr)] lg:items-start">
            <div>
              <span class="tag-pill tag-brand">{track.level}</span>
              <h2 class="mt-4 text-3xl font-semibold tracking-tight text-slate-950">
                {track.icon} {track.title}
              </h2>
              <p class="mt-3 text-sm leading-7 text-slate-600 sm:text-base">
                {track.description}
              </p>
              <p class="mt-4 text-sm font-medium text-brand-700">
                {track.audience}
              </p>
            </div>

            <div class={`grid gap-4 ${track.items.length === 2 ? "md:grid-cols-2" : "md:grid-cols-2 xl:grid-cols-3"}`}>
              {track.items.map((item) => (
                <a
                  href={item.href}
                  class="rounded-[24px] border border-slate-100 bg-slate-50/70 p-5 transition hover:border-brand-200 hover:bg-white"
                >
                  <div class="flex items-center justify-between gap-3">
                    <span class="text-sm font-medium text-slate-500">{item.duration}</span>
                    <span class="text-brand-700">→</span>
                  </div>
                  <h3 class="mt-4 text-xl font-semibold tracking-tight text-slate-950">
                    {item.title}
                  </h3>
                  <p class="mt-3 text-sm leading-7 text-slate-600">
                    {item.description}
                  </p>
                  <div class="mt-4 border-t border-slate-200 pt-4 text-sm text-slate-500">
                    学完后你能：{item.outcome}
                  </div>
                </a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="section-shell pt-0">
    <div class="surface-card overflow-hidden bg-slate-950 px-6 py-10 text-center text-white sm:px-10 sm:py-14 lg:px-16">
      <span class="eyebrow border-slate-700 bg-slate-900 text-brand-300">
        Next Step
      </span>
      <h2 class="mt-5 text-3xl font-semibold tracking-tight sm:text-4xl">
        学完教程后，马上去挑一个技能跑通结果
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-base leading-7 text-slate-300 sm:text-lg">
        学习和实操最好连在一起。读完一个阶段，就回技能商店找一个最接近业务的能力去验证。
      </p>
      <div class="mt-8 flex flex-col justify-center gap-3 sm:flex-row">
        <a href="/skills" class="primary-button">
          去选技能
        </a>
        <a href="/" class="secondary-button border-slate-700 bg-slate-900 text-white hover:border-brand-400 hover:text-brand-200">
          返回首页
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
