---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const tutorials = await getCollection('tutorials');
  return tutorials.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const { title, description, duration, difficulty, outcome } = entry.data;

const difficultyColor = {
  '入门': 'bg-emerald-100 text-emerald-700',
  '进阶': 'bg-amber-100 text-amber-700',
  '实战': 'bg-red-100 text-red-700',
}[difficulty] ?? 'bg-slate-100 text-slate-700';
---

<BaseLayout title={title} description={description}>
  <div class="mx-auto max-w-3xl px-4 py-10 sm:px-6 lg:px-8">
    <!-- 返回按钮 -->
    <a
      href="/tutorials"
      class="inline-flex items-center gap-2 text-sm font-medium text-slate-500 transition hover:text-brand-600"
    >
      ← 返回教程列表
    </a>

    <!-- 文章头部 -->
    <div class="mt-8 border-b border-slate-100 pb-8">
      <div class="flex flex-wrap items-center gap-3">
        <span class={`rounded-full px-3 py-1 text-xs font-semibold ${difficultyColor}`}>
          {difficulty}
        </span>
        <span class="text-sm text-slate-400">⏱ {duration}</span>
      </div>
      <h1 class="mt-4 text-3xl font-bold tracking-tight text-slate-950 sm:text-4xl">
        {title}
      </h1>
      <p class="mt-3 text-base leading-7 text-slate-600">{description}</p>
      <div class="mt-4 rounded-xl bg-brand-50 px-4 py-3 text-sm font-medium text-brand-700">
        🎯 学完后你能：{outcome}
      </div>
    </div>

    <!-- 正文内容 -->
    <div class="prose prose-slate mt-8 max-w-none
      prose-headings:font-semibold prose-headings:tracking-tight
      prose-h2:text-xl prose-h2:mt-8 prose-h2:mb-4
      prose-h3:text-base prose-h3:mt-6 prose-h3:mb-2
      prose-p:leading-7 prose-p:text-slate-700
      prose-code:rounded prose-code:bg-slate-100 prose-code:px-1.5 prose-code:py-0.5 prose-code:text-sm prose-code:text-brand-700 prose-code:font-mono
      prose-pre:rounded-xl prose-pre:bg-slate-950 prose-pre:text-slate-100
      prose-a:text-brand-600 prose-a:no-underline hover:prose-a:underline
      prose-blockquote:border-l-brand-400 prose-blockquote:text-slate-600
      prose-strong:text-slate-900
      prose-li:text-slate-700
      prose-hr:border-slate-200">
      <Content />
    </div>

    <!-- 底部导航 -->
    <div class="mt-12 border-t border-slate-100 pt-8">
      <a
        href="/tutorials"
        class="inline-flex items-center gap-2 rounded-full bg-slate-100 px-5 py-2.5 text-sm font-medium text-slate-700 transition hover:bg-slate-200"
      >
        ← 返回教程列表
      </a>
    </div>
  </div>
</BaseLayout>
